---
import Icon from './Icon.astro';
---

<section id="hero" class="min-h-screen flex items-center justify-center md:pt-20 md:pl-20 relative overflow-hidden">

  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
    <div id="hero-text-content">
      <div class="inline-block px-3 py-1 mb-4 border border-brand-blue/30 rounded-full bg-brand-blue/10">
        <span class="text-brand-blue font-mono text-sm">Wirtschaftsinformatik Student</span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">
        Hey, Ich bin <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue to-white">Nicolas Burbano</span>
      </h1>
      <p class="text-gray-400 text-lg mb-8 max-w-lg leading-relaxed">
        Ich interessiere mich für Data Engineering, Backend und Cloud-Technologien. 
        Mein Ziel ist es, mithilfe von Technologie Geschäftsprozesse effizienter zu gestalten.
      </p>
      

      <div class="mt-3 flex gap-6">
        <a href="https://github.com/dnburp4" class="text-gray-400 hover:text-brand-blue transition-colors">
          <Icon name="Github" size={24} />
        </a>
        <a href="https://www.linkedin.com/in/dnicolasburbanop/" class="text-gray-400 hover:text-brand-blue transition-colors">
          <Icon name="Linkedin" size={24} />
        </a>
      </div>
    </div>


      {/* Decorative elements */}
      <div class="absolute -top-4 -right-4 w-24 h-24 border-t-2 border-r-2 border-brand-orange rounded-tr-3xl"></div>
      <div class="absolute -bottom-4 -left-4 w-24 h-24 border-b-2 border-l-2 border-brand-blue rounded-bl-3xl"></div>
    </div>
  </div>
</section>


