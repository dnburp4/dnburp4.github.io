---
import Icon from './Icon.astro';

export interface Props {
  title: string;
  description: string;
  tags: string[];
  video: string;
  githubUrl?: string;
  liveUrl?: string;
  index: number;
}

const { title, description, tags, video, githubUrl, liveUrl, index } = Astro.props;
---

<div
  data-index={index}
  class="project-card group relative bg-zinc-900 rounded-2xl overflow-hidden border border-white/5 hover:border-brand-blue/30 transition-all duration-300"
>
  <div class="aspect-video overflow-hidden relative">
    <div class="absolute inset-0 bg-brand-blue/20 opacity-0 group-hover:opacity-100 transition-opacity z-10"></div>
      <video 
        autoplay
        muted
        loop
        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
      >
        <source src={video} type='video/mp4' />
      </video>


      


  </div>
  
  <div class="p-6">
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => (
        <span 
          class="px-3 py-1 text-xs font-mono rounded-full bg-white/5 text-gray-300 border border-white/5"
        >
          {tag}
        </span>
      ))}
    </div>
    
    <h3 class="text-2xl font-bold mb-3 group-hover:text-brand-blue transition-colors">{title}</h3>
    <p class="text-gray-400 mb-6 line-clamp-3">{description}</p>
    
    <div class="flex gap-4">
      {githubUrl && (
        <a 
          href={githubUrl} 
          class="flex items-center gap-2 text-sm font-medium text-white hover:text-brand-orange transition-colors"
        >
          <Icon name="Github" size={18} /> Code
        </a>
      )}
      {liveUrl && (
        <a 
          href={liveUrl} 
          class="flex items-center gap-2 text-sm font-medium text-white hover:text-brand-blue transition-colors"
        >
          <Icon name="ExternalLink" size={18} /> Live Demo
        </a>
      )}
    </div>
  </div>
</div>
